<Page x:Class="Expense_Report.Report"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Expense_Report"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="580"
      Title="Report">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Screenshot 2026-02-18 092707.png"></ImageBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Label Grid.Column="1" Foreground="White" FontSize="20" HorizontalAlignment="Left"  VerticalAlignment="Center">Expense Report For:</Label>

        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MinHeight="21"/>
                <RowDefinition Height="Auto" MinHeight="30.96"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <DockPanel Margin="0,0,0,26" Grid.RowSpan="2">
                <Label Style="{DynamicResource headerTextStyle}" HorizontalAlignment="Left" VerticalAlignment="Top">Name :</Label>
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Top" Margin="5,6,0,0" Foreground="White" Name="Name"  Text=""></TextBlock>
            </DockPanel>
            <DockPanel Grid.Row="1" VerticalAlignment="Center" Height="26">
                <Label Style="{StaticResource headerTextStyle}" HorizontalAlignment="Left" VerticalAlignment="Top" >Departement :</Label>
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Top" Margin="5,6,0,0" Foreground="White" Name="Departement" Text=""></TextBlock>
            </DockPanel>
            <DataGrid x:Name="ReportList" BorderBrush="Transparent" IsReadOnly="True" Background="White" RowHeaderWidth="0" Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Left" VerticalAlignment="Top" Width="Auto" Height="Auto">
            </DataGrid>
        </Grid>
    </Grid>
</Page>
